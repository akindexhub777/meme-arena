<!DOCTYPE html>
<html lang="fr" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Meme Arena ⚔️</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
  <style>
    body {
      background: linear-gradient(135deg, #0f0a1f 0%, #1a0033 50%, #0a0a0a 100%);
    }
    .arena-glow {
      box-shadow: 0 0 40px -10px rgb(168 85 247);
    }
    .meme-card {
      transition: all 0.5s cubic-bezier(0.4, 0.0, 0.2, 1);
    }
    .meme-card:hover {
      transform: translateY(-15px) scale(1.04);
      box-shadow: 0 30px 60px -15px rgb(34 211 238 / 0.5);
    }
  </style>
</head>
<body class="min-h-screen text-white">

  <!-- HEADER -->
  <header class="border-b border-purple-500/30 bg-black/80 backdrop-blur-xl sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-6 py-5 flex items-center justify-between">
      <div class="flex items-center gap-4">
        <div class="w-14 h-14 bg-gradient-to-br from-purple-600 via-fuchsia-500 to-cyan-500 rounded-3xl flex items-center justify-center text-4xl rotate-12 shadow-2xl">
          ⚔️
        </div>
        <div>
          <h1 class="text-5xl font-black tracking-tighter bg-gradient-to-r from-purple-400 to-cyan-400 bg-clip-text text-transparent">
            MEME ARENA
          </h1>
          <p class="text-sm text-cyan-300 tracking-widest">POWERED BY GENLAYER INTELLIGENT CONTRACTS</p>
        </div>
      </div>

      <button id="connectBtn" class="flex items-center gap-3 bg-zinc-900 hover:bg-zinc-800 border border-purple-500 px-6 py-3 rounded-2xl font-semibold transition-all">
        <i class="fa-solid fa-wallet"></i>
        <span>Connect Wallet</span>
      </button>
    </div>
  </header>

  <!-- HERO -->
  <section class="max-w-7xl mx-auto px-6 pt-20 pb-16 text-center">
    <div class="inline-flex items-center gap-2 bg-purple-900/30 text-purple-300 text-sm px-6 py-2 rounded-full mb-6">
      <span class="animate-pulse">●</span> LIVE ON GENLAYER TESTNET
    </div>
    <h2 class="text-6xl md:text-7xl font-black tracking-tighter leading-tight mb-6">
      QUE LE MEILLEUR<br><span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-cyan-400">MEME GAGNE</span>
    </h2>
    <p class="text-xl text-gray-400 max-w-xl mx-auto">
      Soumets ton meme → L'Intelligent Contract GenLayer le juge avec l'IA et attribue un score objectif
    </p>
    
    <button id="submitBtn" 
            class="mt-10 px-12 py-6 text-2xl font-bold rounded-3xl bg-gradient-to-r from-purple-600 to-cyan-500 hover:from-purple-700 hover:to-cyan-600 flex items-center gap-4 mx-auto shadow-2xl shadow-purple-600/50 transition-all">
      <i class="fa-solid fa-fire-flame-curved"></i>
      SUBMIT YOUR MEME TO THE ARENA
    </button>
  </section>

  <!-- TOP MEMES -->
  <section class="max-w-7xl mx-auto px-6 pb-24">
    <div class="flex justify-between items-end mb-10">
      <h3 class="text-4xl font-bold">🏆 TOP ARENA BATTLES</h3>
      <p class="text-cyan-400 flex items-center gap-2">
        <i class="fa-solid fa-bolt"></i> Scoring par Intelligent Contract GenLayer
      </p>
    </div>

    <div id="memesGrid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
      <!-- Cartes générées par JS -->
    </div>
  </section>

  <script>
    const memes = [
      {
        id: 1,
        image: "https://picsum.photos/id/237/800/800",
        description: "Quand le testnet GenLayer droppe enfin",
        score: 96,
        wallet: "0x71C7...a3f9",
        votes: 1248,
        judgedBy: "GenLayer AI"
      },
      {
        id: 2,
        image: "https://picsum.photos/id/201/800/800",
        description: "Moi attendant le mainnet",
        score: 91,
        wallet: "0x8D4b...f2e1",
        votes: 987,
        judgedBy: "GenLayer AI"
      },
      {
        id: 3,
        image: "https://picsum.photos/id/180/800/800",
        description: "Les validators IA en train de juger mon meme",
        score: 98,
        wallet: "0xB3a9...7c2d",
        votes: 1567,
        judgedBy: "GenLayer AI"
      }
    ];

    function createCard(meme) {
      const card = document.createElement('div');
      card.className = "meme-card bg-zinc-950 border border-purple-500/30 rounded-3xl overflow-hidden arena-glow";
      card.innerHTML = `
        <div class="relative">
          <img src="${meme.image}" class="w-full aspect-square object-cover">
          <div class="absolute top-4 right-4 bg-black/80 text-3xl font-black px-5 py-2 rounded-2xl flex items-center gap-2 border border-yellow-400/30">
            ${meme.score}
            <span class="text-yellow-400 text-2xl">★</span>
          </div>
        </div>
        <div class="p-6">
          <p class="font-medium text-lg leading-tight mb-5 line-clamp-2">${meme.description}</p>
          
          <div class="flex justify-between items-center text-sm">
            <div>
              <span class="text-gray-500">Submitted by</span><br>
              <span class="font-mono text-purple-400">${meme.wallet}</span>
            </div>
            <div class="text-right">
              <span class="text-cyan-400">${meme.votes} votes</span><br>
              <span class="text-xs text-gray-500">Judged by ${meme.judgedBy}</span>
            </div>
          </div>
        </div>
      `;
      return card;
    }

    function renderMemes() {
      const grid = document.getElementById('memesGrid');
      grid.innerHTML = '';
      memes.forEach(m => grid.appendChild(createCard(m)));
    }

    // Boutons
    document.getElementById('submitBtn').addEventListener('click', () => {
      alert("Modal de submission ouvert !\n\nIci tu pourras uploader ton meme → l'Intelligent Contract GenLayer le jugera automatiquement (humour, viralité, créativité).");
    });

    document.getElementById('connectBtn').addEventListener('click', () => {
      alert("Wallet connecté (prêt pour genlayer-js)");
    });

    renderMemes();
  </script>
</body>
</html>
